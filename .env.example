# Copy this file to .env and fill in real values. NEVER commit .env to git.

# LLM keys — you only need the one matching llm.provider in config/settings.yaml.
# Gemini (free tier): aistudio.google.com -> Get API key
GEMINI_API_KEY=
# Anthropic (paid): console.anthropic.com
ANTHROPIC_API_KEY=

# Yutori API key (scraping + NLP enrichment of non-RSS sources)
YUTORI_API_KEY=

# Email delivery (Gmail: use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=
EMAIL_FROM=you@example.com
# Comma-separated recipient list
EMAIL_TO=exec1@example.com,exec2@example.com
